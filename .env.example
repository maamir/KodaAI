# Environment
NODE_ENV=development

# Server
PORT=4000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/aidlc

# Security
ENCRYPTION_KEY=<encryption_key>

# Logging
LOG_LEVEL=info

# Redis (for job queue)
REDIS_URL=redis://localhost:6379

# External URLs (optional)
DASHBOARD_URL=http://localhost:3000

# Unit 2: Integration Module Configuration

# Worker Mode (set to true for background worker)
WORKER_MODE=false

# Jira Integration (optional)
JIRA_EMAIL=user@example.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_BASE_URL=https://your-domain.atlassian.net

# GitHub Integration (optional)
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----
GITHUB_INSTALLATION_ID=78901

# Integration Settings
INTEGRATION_CACHE_TTL=900
INTEGRATION_JOB_POLL_INTERVAL=5000
INTEGRATION_MAX_RETRIES=3
INTEGRATION_RATE_LIMIT_THRESHOLD=0.2

# Unit 3: Reporting and Visualization Configuration

# AWS S3 Configuration (for report storage - optional, has local fallback)
AWS_REGION=us-east-1
AWS_S3_BUCKET=aidlc-reports
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# Report Configuration
REPORT_EXPIRATION_DAYS=7
REPORT_MAX_SIZE_MB=50
REPORT_GENERATION_TIMEOUT_MS=300000

# Metric Calculation Configuration
METRIC_CALCULATION_BATCH_SIZE=10
METRIC_CALCULATION_TIMEOUT_MS=60000
HOURLY_RATE=100

# Dashboard Configuration
DASHBOARD_CACHE_TTL_SECONDS=300
DASHBOARD_MAX_WIDGETS=12
DASHBOARD_MAX_DATA_POINTS=1000

# Analytics Configuration (optional)
ANALYTICS_ENABLED=false
ANALYTICS_API_KEY=your_analytics_api_key
